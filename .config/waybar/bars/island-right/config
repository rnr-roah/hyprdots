  "tooltip": false
},







    "custom/power_mode": {
      "format": "<span>{}</span>",
      "exec": "~/.config/waybar/scripts/power_mode_toggle.sh",
      "on-click": "~/.config/waybar/scripts/power_mode_toggle.sh toggle",
      "interval": 5,
      "return-type": "json",
      "tooltip-format": "Power mode: {}"
    },

    "custom/island-sep1": { "format": "", "tooltip": false },
    "custom/island-sep2": { "format": "", "tooltip": false },
    "custom/island-sep3": { "format": "", "tooltip": false },
    "custom/island-sep4": { "format": "", "tooltip": false },
    "custom/island-sep5": { "format": "", "tooltip": false },

