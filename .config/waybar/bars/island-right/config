[
  {
    "name": "topbar",
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "height": 20,

    "modules-left": [
      "custom/window-name"
    ],
    "modules-center": [
      "clock"],
    "modules-right": [
    ],

    "custom/window-name": {
      "format": "{}",
      "interval": 1,
      "max-length": 60,
      "exec": "~/.config/waybar/scripts/window-name.sh"
    },

    "clock": {
      "format": "<span color='#b69bf1'> </span>{:%I:%M %p}",
      "format-alt": "<span foreground='#b69bf1'></span>{:%H:%M  %A %B %d}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "on-click-right": "flipclock"
    }
  },









  {
    "name": "island",
    "layer": "top",
    "position": "right",
    "exclusive": true,
