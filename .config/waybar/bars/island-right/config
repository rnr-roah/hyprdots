"custom/playing": {
  "exec": "~/.config/waybar/scripts/playing.sh",
  "format": "{}",
  "tail": true,
  "tooltip": false
},
"custom/media-sep": { "format": "", "tooltip": false },

"custom/media-prev": {
  "exec": "echo 'οÜë'",
  "exec-if": "playerctl -a status 2>/dev/null | grep -qE 'Playing|Paused'",
  "interval": 1,
  "format": "{}",
  "on-click": "playerctl -a previous",
  "tooltip": false
},

