* {
    font:               "JetBrainsMono Nerd Font 13";
    border:             0;
    margin:             0;
    padding:            0;
    spacing:            0;
}

window {
    background-color:   transparent;
    border:             0;
    border-radius:      0;
    padding:            0;
    width:              560px;
    location:           south;
    anchor:             south;
    fixed-height:       false;
    y-offset:           -40px;
}

mainbox {
    background-color:   transparent;
    spacing:            8px;
    padding:            0;
    children:           [ listview, inputbar ];
}

inputbar {
    background-color:   #1e202580;
    border:             2px solid;
    border-color:       #acc7ff;
    border-radius:      20px;
    padding:            12px 16px;
    spacing:            8px;
    children:           [ prompt, entry ];
}

prompt {
    background-color:   transparent;
    text-color:         #acc7ffff;
    font:               "JetBrainsMono Nerd Font Bold 13";
    vertical-align:     0.5;
}

entry {
    background-color:   transparent;
    text-color:         #c4c6d0;
    placeholder:        "Search";
    placeholder-color:  #c4c6d0;
    vertical-align:     0.5;
    expand:             true;
}

listview {
    background-color:   #1e202580;
    border:             1px solid;
    border-color:       #8e9099aa;
    border-radius:      20px;
    spacing:            2px;
    padding:            6px;
    lines:              6;
    cycle:              false;
    dynamic:            true;
    scrollbar:          false;
    fixed-height:       false;
    reverse:            true;
}

element {
    background-color:   transparent;
    border-radius:      20px;
    padding:            11px 16px;
    spacing:            12px;
    orientation:        horizontal;
    children:           [ element-icon, element-text ];
}

element normal.normal {
    background-color:   transparent;
    text-color:         #e2e2e9;
}

element selected.normal {
    background-color:   #acc7ff;
    text-color:         #0f2f60;
}

element alternate.normal {
    background-color:   transparent;
    text-color:         #e2e2e9;
}

element-icon {
    background-color:   transparent;
    size:               26px;
    vertical-align:     0.5;
}

element-text {
    background-color:   transparent;
    text-color:         inherit;
    vertical-align:     0.5;
    expand:             true;
}
