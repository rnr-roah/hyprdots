* {
    bg0:    {{ colors.surface.default.hex }}F2;
    bg1:    {{ colors.surface_variant.default.hex }};
    bg2:    {{ colors.surface_variant.default.hex }}80;
    bg3:    {{ colors.primary.default.hex }}F2;
    fg0:    {{ colors.on_surface.default.hex }};
    fg1:    {{ colors.on_primary.default.hex }};
    fg2:    {{ colors.on_surface_variant.default.hex }};
    fg3:    {{ colors.surface_variant.default.hex }};
}
